{
    "name": "azure-migration-analyzer/sistema-analise-migracao",
    "description": "Sistema de Análise de Migração de Recursos Azure",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Equipe Pré-Vendas",
            "email": "prevendas@empresa.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "phpoffice/phpspreadsheet": "^1.29",
        "phpoffice/phppresentation": "^1.0",
        "mpdf/mpdf": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "AzureMigration\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public"
    }
}
