<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- ============================================================
         LIMITE DE UPLOAD — IIS / Azure App Service
         maxAllowedContentLength em bytes: 209715200 = 200 MB
         Sem este ajuste o IIS retorna 413 antes de o PHP ser chamado.
    ============================================================ -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="209715200" />
      </requestFiltering>
    </security>

    <!-- ============================================================
         CONFIGURAÇÕES PHP
         Espelham o php.ini — necessário pois o App Service ignora
         arquivos .user.ini em alguns planos de hospedagem.
    ============================================================ -->
    <phpIniValues>
      <phpIniValue name="upload_max_filesize" value="200M" />
      <phpIniValue name="post_max_size"       value="210M" />
      <phpIniValue name="memory_limit"        value="256M" />
      <phpIniValue name="max_execution_time"  value="300"  />
      <phpIniValue name="max_input_time"      value="300"  />
    </phpIniValues>

    <!-- ============================================================
         ROTEAMENTO — garante que index.php sirva como default
         e que arquivos estáticos sejam servidos diretamente.
    ============================================================ -->
    <defaultDocument>
      <files>
        <clear />
        <add value="home.php" />
      </files>
    </defaultDocument>

    <rewrite>
      <rules>
        <!-- Serve arquivos e diretórios existentes diretamente -->
        <rule name="StaticFiles" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>
        <!-- Rota tudo mais para home.php -->
        <rule name="FallbackToHome" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="home.php" />
        </rule>
      </rules>
    </rewrite>

    <!-- Aumenta timeout da conexão HTTP para uploads grandes -->
    <httpErrors errorMode="DetailedLocalOnly" />

  </system.webServer>
</configuration>
